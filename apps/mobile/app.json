{
  "expo": {
    "name": "IdeaMode",
    "slug": "ideamode",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ideamode",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#fafafa"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ai.ideamode.app",
      "jsEngine": "jsc"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#fafafa"
      },
      "package": "ai.ideamode.app",
      "jsEngine": "jsc"
    },
    "plugins": ["expo-router"]
  }
}
